# Control-plane Django (SECONDAIRE / optionnel) — copier en django/.env avant usage.
# Placeholders uniquement : aucune valeur réelle ici.

# Clé secrète Django — OBLIGATOIRE en production. Générer :
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=

# Ne jamais laisser DEBUG=true en production.
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=

# Chiffrement AES-256-GCM des credentials — MÊME valeur que le service Node
# (CREDENTIALS_ENCRYPTION_KEY). 32 octets en base64.
CREDENTIALS_ENCRYPTION_KEY=

# Base Postgres (si POSTGRES_DB absent ⇒ SQLite local en dev).
POSTGRES_DB=rs_connector
POSTGRES_USER=rs_connector
POSTGRES_PASSWORD=changeme-generate-a-real-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
