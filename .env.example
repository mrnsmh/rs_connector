# Copier ce fichier en .env avant de lancer docker compose.
# rs-connector est indépendant : aucune variable ici n'est partagée avec un autre service.

PORT=3007
LOG_LEVEL=info

# Secret HMAC global de repli pour signer les webhooks sortants (v1).
# À terme, chaque application branchée aura son propre secret (voir PLAN-TACHES.md).
WEBHOOK_SECRET=changeme-generate-a-real-secret

# URL webhook de repli si une connexion/application n'en configure pas.
DEFAULT_WEBHOOK_URL=

# URL publique de base du service (ex. https://rs-connector.example.com), affichée aux applications
# comme endpoint à appeler (panneau « Endpoint d'intégration » du back-office). Vide ⇒ déduite
# de la requête (peu fiable derrière un proxy — à fixer en prod).
PUBLIC_BASE_URL=

# WhatsApp Cloud API (Meta) — webhook entrant.
# verify_token : chaîne libre, à recopier dans la config du webhook côté Meta.
# app_secret : secret de l'app Meta, pour vérifier la signature des POST entrants.
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_GRAPH_VERSION=v21.0

# Back-office sécurisé (admin). En dev HTTP local, mettre ADMIN_COOKIE_SECURE=false.
ADMIN_TOTP_ISSUER=rs-connector
ADMIN_SESSION_TTL=43200
ADMIN_COOKIE_SECURE=true

# Chiffrement AES-256-GCM des credentials au repos (Task 11). 32 octets en base64.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# (ou : node scripts/generate-key.js). À garder HORS de la base, en secret.
CREDENTIALS_ENCRYPTION_KEY=

# Base Postgres dédiée à rs-connector — totalement séparée des autres services.
DB_NAME=rs_connector
DB_USER=rs_connector
DB_PASSWORD=changeme-generate-a-real-password
